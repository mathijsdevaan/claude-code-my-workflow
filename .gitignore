# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Data files — actual data lives in Box, not in git
# See .claude/rules/data-storage.md for the convention.
# data/PROVENANCE.md is kept; data payloads are not.
data/raw/
data/processed/
data/intermediate/
data/archive/
data/*.csv
data/*.RData
data/*.Rdata
data/*.rds
data/*.dta
data/*.sav
data/*.zsav
data/*.feather
data/*.parquet
data/*.xlsx
data/*.xls
# Common-sense catch: any large binary that slipped past, blocked by the
# pre-commit hook at scripts/git-hooks/pre-commit.
